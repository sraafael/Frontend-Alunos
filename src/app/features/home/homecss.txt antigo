.bg-ice {
  background: linear-gradient(135deg, #e8f5e9, #e3f2fd);
}

.role-card {
  background: #ffffff;
  border-radius: 28px;
  padding: 40px;
  min-height: 320px;
  border: 2px solid transparent;
  box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.role-card.professor:hover {
  border-color: rgba(47, 128, 255, 0.35);
  box-shadow: 0 25px 55px rgba(47, 128, 255, 0.25);
  transform: translateY(-6px);
}

.role-card.aluno:hover {
  border-color: rgba(0, 181, 106, 0.35);
  box-shadow: 0 25px 55px rgba(0, 181, 106, 0.25);
  transform: translateY(-6px);
}

.icon-box {
  width: 60px;
  height: 60px;
  border-radius: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  color: #fff;
  margin-bottom: 28px;
}

.icon-box.professor {
  background: #2f80ff;
}

.icon-box.aluno {
  background: #00b56a;
}

.role-card h4 {
  font-weight: 700;
  font-size: 22px;
  margin-bottom: 16px;
  color: #0f172a;
}

.role-card p {
  font-size: 15px;
  line-height: 1.7;
  color: #64748b;
}

.btn-professor {
  background: #2f80ff;
  color: #ffffff;
  border-radius: 14px;
  padding: 14px;
  font-weight: 600;
  border: none;
}

.btn-professor:hover {
  background: #2569d9;
}

.btn-aluno {
  background: #00b56a;
  color: #ffffff;
  border-radius: 14px;
  padding: 14px;
  font-weight: 600;
  border: none;
}

.btn-aluno:hover {
  background: #009a5a;
}

.subtitle {
  position: relative;
  top: -70px;
  font-size: 17;
}

.info-link-container {
  position: absolute;
  top: 20px;
  right: 30px;
}

.info-link {
  display: flex;
  align-items: center;
  gap: 6px;
  text-decoration: none;
  font-size: 1.2rem;
  color: #6b7280;
  font-weight: 500;
  transition: all 0.2s ease;
}

.info-link i {
  font-size: 1.5rem;
}

.info-link:hover {
  color: #2563eb;
  transform: translateY(-1px);
}