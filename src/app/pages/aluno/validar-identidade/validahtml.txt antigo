<app-header title="Entrar em um Grupo" subtitle="Junte-se ao seu grupo de estudo" backLink="/">
</app-header>

<div class="page aluno">
  <div class="page-content">
    <div class="card">
      <h3>Informe seu nome para acessar a atividade</h3>

      <form>

        <label for="name">Nome</label>
        <input id="name" type="text" placeholder="Digite seu nome" [(ngModel)]="nome" name="nome" required />

        <label for="sobrenome">Sobrenome</label>
        <input id="sobrenome" type="text" placeholder="Digite seu sobrenome" [(ngModel)]="sobrenome" name="sobrenome"
          required />

        <small class="helper">
          É necessário informar o nome e sobrenome
        </small>

        <button type="button" class="btn-confirm" (click)="validarNome()" [disabled]="!nome || !sobrenome">
          Validar Nome
        </button>

      </form>
    </div>
  </div>
</div>

<!-- Modal Sucesso -->
<div class="modal-custom" [class.ativo]="mostrarModalSucesso">
  <div class="modal-card">
    <div class="success-icon mb-4">
      <i class="bi bi-check-circle-fill"></i>
    </div>

    <h4 class="fw-bold mb-2">Bem-vindo, {{ nome }}!</h4>

    <p class="text-muted mb-4">
      Validação realizada com sucesso.
    </p>

    <button class="btn-confirm" (click)="irParaGrupos()">
      Continuar
    </button>
  </div>
</div>

<!-- Modal Erro -->
<div class="modal-custom" [class.ativo]="mostrarModalErro">
  <div class="modal-card">
    <div class="err-icon mb-4">
      <i class="bi bi-x-circle-fill"></i>
    </div>

    <h4 class="fw-bold mb-2">Erro!</h4>

    <p class="text-muted mb-4">
      Já existe aluno cadastrado com esse nome.
    </p>

    <button class="btn-err" (click)="mostrarModalErro = false">
      Continuar
    </button>
  </div>
</div>

<!-- Backdrop -->
<div class="modal-backdrop-custom" *ngIf="mostrarModalSucesso || mostrarModalErro">
</div>